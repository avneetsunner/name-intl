{
  "name": "name-intl",
  "version": "3.0.1",
  "description": "A JS helper for formatting names of persons according to locale.",
  "homepage": "https://github.com/avneetsunner/name-intl",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/avneetsunner/name-intl.git"
  },
  "bugs": {
    "url": "https://github.com/avneetsunner/name-intl/issues"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "index.d.ts"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --tsconfig tsconfig.build.json",
    "test": "node --test --import tsx ./src/index.test.ts",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "person",
    "human",
    "name",
    "converstion",
    "order",
    "localization",
    "intl",
    "namelocalization",
    "internationalize"
  ],
  "author": "Avneet Sunner",
  "type": "module",
  "license": "ISC",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "ts-node": "^10.9.2",
    "tsup": "^8.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  }
}
